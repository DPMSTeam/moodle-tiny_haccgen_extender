{{!
    @template tiny_haccgen_extender/components/result-dialog-card

    Result area for the Haccgen extender result dialog. Media tags are output in-template from URLs
    so they are never stripped (no raw HTML in variables).

    Example context (json):
    {
        "isText": true,
        "textContent": "Example output text"
    }

    @copyright 2026, Dynamic Pixel
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
{{#hasTimestamps}}
<div class="dp-ai-result-timestamps">{{#generationTimeDisplay}}{{generationTimeDisplay}}{{/generationTimeDisplay}}{{#dialogTimeDisplay}}{{#generationTimeDisplay}} · {{/generationTimeDisplay}}{{dialogTimeDisplay}}{{/dialogTimeDisplay}}</div>
{{/hasTimestamps}}
<div class="dp-ai-result-text dp-ai-result-card{{#wrapperClass}} {{wrapperClass}}{{/wrapperClass}}{{#isText}} dp-ai-result-text-scroll{{/isText}}" data-text="result">
    <p class="dp-ai-result-body">
    {{#audioIframeSrc}}
    <iframe class="dp-audio-iframe" title="Audio player" width="100%" height="80" src="{{{audioIframeSrc}}}"></iframe>
    {{/audioIframeSrc}}
    {{^audioIframeSrc}}
    {{#resultText}}
    {{{resultText}}}
    {{/resultText}}
    {{^resultText}}
    {{#isAudio}}
    {{#audioHtml}}
    {{{audioHtml}}}
    {{/audioHtml}}
    {{^audioHtml}}
    {{#audioSrc}}
    <audio class="dp-audio-player" controls preload="metadata" src="{{{audioSrc}}}">Your browser does not support audio.</audio>
    {{/audioSrc}}
    {{/audioHtml}}
    {{/isAudio}}
    {{#isImage}}
    <img src="{{imageSrc}}" class="mw-100 dp-ai-result-media" alt="Generated image">
    {{/isImage}}
    {{#isVideo}}
    <video controls preload="metadata" class="mw-100 dp-ai-result-media" src="{{videoUrl}}">Your browser does not support video.</video>
    {{/isVideo}}
    {{#isImageIntentNoImage}}
    No image could be extracted from the response. The service may return a different format.
    <div class="dp-ai-result-raw-response-label">Raw response (first 500 chars):</div>
    <pre class="dp-ai-result-raw-response-preview">{{imageErrorPreview}}</pre>
    {{/isImageIntentNoImage}}
    {{#isText}}
    {{#beautifiedContent}}
    <div class="dp-ai-result-html">{{{beautifiedContent}}}</div>
    {{/beautifiedContent}}
    {{^beautifiedContent}}
    <pre class="dp-ai-result-text-pre">{{textContent}}</pre>
    {{/beautifiedContent}}
    {{/isText}}
    {{/resultText}}
    {{/audioIframeSrc}}
    </p>
    {{#errorMessage}}
    <div class="dp-ai-result-error">{{errorMessage}}</div>
    {{/errorMessage}}
</div>
