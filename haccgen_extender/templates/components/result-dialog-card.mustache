{{!
@template tiny_haccgen_extender/components/result-dialog-card

Result area for the Haccgen extender result dialog. Media tags are output in-template from URLs
so they are never stripped (no raw HTML in variables).
}}
{{#hasTimestamps}}
<div class="dp-ai-result-timestamps" style="margin-bottom:10px;font-size:12px;opacity:.8;color:var(--dp-ai-muted,rgba(15,31,46,.70));">{{#generationTimeDisplay}}{{generationTimeDisplay}}{{/generationTimeDisplay}}{{#dialogTimeDisplay}}{{#generationTimeDisplay}} · {{/generationTimeDisplay}}{{dialogTimeDisplay}}{{/dialogTimeDisplay}}</div>
{{/hasTimestamps}}
<style>
  /* Keep result preview bounded so dialog action buttons stay visible. */
  .tox .dp-ai-result-text {
    width: 100%;
    max-height: min(56vh, 460px);
    overflow: auto;
  }

  .tox .dp-ai-result-text img.mw-100,
  .tox .dp-ai-result-text video.mw-100 {
    max-height: min(40vh, 340px) !important;
    height: auto !important;
  }

  .tox .dp-ai-result-text iframe.dp-audio-iframe {
    max-width: 100%;
  }
</style>
<div class="dp-ai-result-text{{#wrapperClass}} {{wrapperClass}}{{/wrapperClass}}" style="{{wrapperStyle}}{{#wrapperExtraStyle}} {{wrapperExtraStyle}}{{/wrapperExtraStyle}}" data-text="result">
    <p style="{{pStyle}}">
    {{#audioIframeSrc}}
    <iframe class="dp-audio-iframe" src="{{{audioIframeSrc}}}" width="100%" height="80" style="max-width:400px;border:0;" title="Audio player"></iframe>
    {{/audioIframeSrc}}
    {{#isImage}}
    <img src="{{imageSrc}}" class="mw-100" style="{{imgStyle}}" alt="Generated image" />
    {{/isImage}}
    {{#isVideo}}
    <video controls preload="metadata" class="mw-100" style="{{imgStyle}}" src="{{videoUrl}}">Your browser does not support video.</video>
    {{/isVideo}}
    {{#isImageIntentNoImage}}
    No image could be extracted from the response. The service may return a different format.
    <div style="margin-top:8px;font-size:12px;opacity:.85;">Raw response (first 500 chars):</div>
    <pre style="margin:4px 0 0;padding:8px;background:rgba(0,0,0,.05);border-radius:4px;font-size:11px;max-height:120px;overflow:auto;white-space:pre-wrap;word-break:break-word;">{{imageErrorPreview}}</pre>
    {{/isImageIntentNoImage}}
    {{#isText}}
    {{#beautifiedContent}}
    <div class="dp-ai-result-html" style="margin:0;font-size:14px;line-height:1.5;">{{{beautifiedContent}}}</div>
    {{/beautifiedContent}}
    {{^beautifiedContent}}
    <pre style="margin:0;white-space:pre-wrap;word-break:break-word;font-size:13px;line-height:1.45;font-family:monospace;">{{textContent}}</pre>
    {{/beautifiedContent}}
    {{/isText}}
    </p>
    {{#errorMessage}}
    <div style="margin-top:8px; font-size:12px; opacity:.75;">{{errorMessage}}</div>
    {{/errorMessage}}
</div>
