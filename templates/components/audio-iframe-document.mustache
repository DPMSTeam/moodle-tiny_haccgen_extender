{{!
    @template tiny_haccgen_extender/components/audio-iframe-document

    Minimal HTML document for data-URL iframe audio preview.

    Context variables required for this template:
    * audiosrc - Audio source URL.
    * audiomime - Audio MIME type.

    @copyright 2026, Dynamic Pixel
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "audiosrc": "https://example.com/audio.mp3",
        "audiomime": "audio/mpeg"
    }
}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Audio preview</title>
    <style>
        body.dp-audio-doc-body {
            margin: 0;
            padding: 0;
        }
        audio.dp-audio-doc-player {
            width: 100%;
            max-width: 400px;
        }
    </style>
</head>
<body class="dp-audio-doc-body">
    <audio class="dp-audio-doc-player" controls preload="metadata">
        <source src="{{audiosrc}}" type="{{audiomime}}">
    </audio>
</body>
</html>
