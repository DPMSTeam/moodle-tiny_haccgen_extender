{{!
    @template tiny_haccgen_extender/components/loading-overlay

    Loading overlay used by the Tiny Haccgen extender dialogs.

    Context variables required for this template:
    * overlayclass - Additional overlay class names.
    * message - Localized loading text.

    Example context (json):
    {
        "overlayclass": "dp-ai-loading-overlay",
        "message": "Generating..."
    }

    @copyright 2026, Dynamic Pixel
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div role="status" aria-live="polite" class="dp-ai-loading-overlay-base{{#overlayclass}} {{overlayclass}}{{/overlayclass}}">
    <div class="dp-ai-spinner"></div>
    <p class="dp-ai-loading-overlay-message">{{message}}</p>
</div>
