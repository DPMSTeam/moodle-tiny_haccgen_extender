{{!
    @template tiny_haccgen_extender/components/dialog-head

    Reusable title/subtitle header block for Tiny dialog steps.

    Context variables required for this template:
    * title - Header title text.
    * subtitle - Header subtitle text.

    @copyright 2026, Dynamic Pixel
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "title": "Summarize",
        "subtitle": "Choose options and generate."
    }
}}
<div class="dp-ai-x-head">
    <p class="dp-ai-x-head__t">{{title}}</p>
    <p class="dp-ai-x-head__s">{{subtitle}}</p>
</div>
